PORT=9092

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=company_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Auth service integration (required for invitation email existence check)
AUTH_SERVICE_URL=http://localhost:9091

# JWT verification (RS256):
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# or
# JWT_PUBLIC_KEY_PATH=C:/keys/jwt-public.pem

KAFKA_BROKERS=localhost:9000
KAFKA_CLIENT_ID=cms-company-info
KAFKA_GROUP_ID=cms-company-info-group
KAFKA_COMPANY_TOPIC=company

# Optional DB override
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/company_db
