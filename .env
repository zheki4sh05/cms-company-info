PORT=9092

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=company_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# RS256 public key for Bearer JWT verification
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY----------END PUBLIC KEY-----

KAFKA_BROKERS=localhost:9000
KAFKA_CLIENT_ID=cms-company-info
KAFKA_GROUP_ID=cms-company-info-group
KAFKA_COMPANY_TOPIC=company
KAFKA_AUTH_TOPIC=auth_topic

AUTH_SERVICE_URL=http://localhost:9091

# Optional: overrides discrete vars if set
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/company_db
